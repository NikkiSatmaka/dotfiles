[".config/git/gitalias"]
    type = "file"
    url = "https://github.com/GitAlias/gitalias/raw/main/gitalias.txt"
    refreshPeriod = "168h"

[".config/nvim"]
    type = "git-repo"
    url = "github.com-personal:NikkiSatmaka/nvim.git"
    private = true

{{- if eq .chezmoi.os "linux" }}
[".config/mpv"]
    type = "git-repo"
    url = "https://github.com/noelsimbolon/mpv-config.git"
    [".config/mpv".clone]
        args = ["--branch linux"]
    [".config/mpv".pull]
        args = ["--ff-only"]
{{- end }}

{{- if eq .chezmoi.os "windows" }}
["AppData/Roaming/mpv"]
    type = "git-repo"
    url = "https://github.com/noelsimbolon/mpv-config.git"
    [".config/mpv".clone]
        args = ["--branch windows"]
    [".config/mpv".pull]
        args = ["--ff-only"]
{{- end }}
